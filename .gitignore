quant/papers/

# QuantNodes PipelineRunner output
/output/
/.factor_cache/

# Runtime logs (regenerated by every reproduction run)
/logs/

# PipelineRunner binary outputs (regenerated by every backtest, not source of truth)
scripts/output/

# 101 alphas H5 stock-daily binary data (regenerable from upstream source)
quant/factors/101_alphas/data/h5/*.h5

# Per-factor backtest results in 101_alphas (regenerated by every re-run)
quant/factors/101_alphas/stk_alpha_*/backtest/*.json

# Per-factor DuckDB in 101_alphas (regenerated by compute_and_store; 311×2-3MB)
quant/factors/101_alphas/stk_alpha_*/factor.duckdb
quant/factors/101_alphas/stk_alpha_*/factor.duckdb.wal
# Per-factor extracted code in 101_alphas (regenerated by codegen)
quant/factors/101_alphas/stk_alpha_*/code.py
# Per-factor regenerated YAML metadata (rebuild via factor_library.update_index)
quant/factors/101_alphas/stk_alpha_*/factor.yaml

# v2 test scratch dir (was used to validate v2 codegen, kept for regression)
quant/factors_v2_test/

# 因子库 regenerable artifacts (由 chore(repro) 重跑产出)
quant/factors/index.yaml
quant/factors/alpha_*.yaml
quant/factors/stk_alpha_*/
quant/factors/101_alphas/*.yaml
quant/factors/test_telemetry_mock.yaml

